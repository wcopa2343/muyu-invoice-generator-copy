<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Past Invoices - Muyu</title>
	<link rel="stylesheet" href="/css/main.css">
</head>
	<body>
		<div class="shell">
			<aside class="sidebar">
				<header>
					Muyu: Invoice Generator
				</header>
				<nav>
					<a href="/">Create Invoice</a>
					<a class="active" aria-current="page" href="/past-invoices">Past Invoices</a>
					<a href="/settings">Settings</a>
				</nav>
				<footer>
					<span>Logged in as: <%= email %></span>
					<a class="sidebar-action" href="/?changeEmail=1">Change email</a>
				</footer>
			</aside>

			<main>
				<section class="page-header">
					<div>
						<h1>Invoices</h1>
					</div>
				</section>

				<section class="invoice-table-wrap" aria-label="Past invoices">
					<% if (invoices.length === 0) { %>
						<div class="empty-state">
							<h2>No invoices yet</h2>
							<p>Create one to download it here.</p>
							<a class="button" href="/">Create Invoice</a>
						</div>
					<% } else { %>
						<table class="invoice-table">
							<thead>
								<tr>
									<th id="invoice-date">Date</th>
									<th id="invoice-company">Company</th>
									<th id="invoice-total" class="number">Total</th>
									<th id="invoice-action"><span class="sr-only">Action</span></th>
								</tr>
							</thead>
							<tbody>
								<% invoices.forEach(invoice => { %>
									<tr>
										<td headers="invoice-date"><span class="cell-label" aria-hidden="true">Date</span><span><%= new Date(invoice.created_at).toLocaleDateString() %></span></td>
										<td headers="invoice-company"><span class="cell-label" aria-hidden="true">Company</span><span><%= invoice.company_name %></span></td>
										<td headers="invoice-total" class="number"><span class="cell-label" aria-hidden="true">Total</span><span>$<%= parseFloat(invoice.total).toFixed(2) %></span></td>
										<td headers="invoice-action"><span class="cell-label" aria-hidden="true">Action</span><a class="button secondary" href="/download/<%= invoice.id %>">Download</a></td>
									</tr>
								<% }) %>
							</tbody>
						</table>
					<% } %>
				</section>
				</main>
		</div>
</body>
</html>
